{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "zig build",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "build Zig test for debug",
            "type": "shell",
            "command": "zig",
            "args": [
                "build",
                "debug-test",
                "-Ddebug-test-file=${relativeFile}",
                "-Ddebug-test-filter=${input:zigTestFilter}"
            ],
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "zigTestFilter",
            "type": "promptString",
            "description": "Zig --test-filter value",
            "default": "${selectedText}"
        }
    ]
}
